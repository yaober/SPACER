    "\n",
    "model = MIL(all_genes).to(device)\n",
    "criterion = nn.BCELoss().to(device)\n",
    "optimizer = torch.optim.Adam(model.parameters(), lr=0.0001)\n",
    "num_epochs = 1\n",
    "patience = 5\n",
    "early_stopping = EarlyStopping(patience=patience, delta=0.0001)"
   ]
