    "def evaluate_model(model, dataloader, device, index_to_evaluate):\n",
    "    model.eval()\n",
    "    total = 0\n",
    "    correct = 0\n",
    "    stored_weights = []\n",
    "\n",
    "    with torch.no_grad():\n",
    "        for idx, (instances, label) in enumerate(dataloader):\n",
    "            if idx == index_to_evaluate:\n",
    "                instances = [torch.tensor(np.array(instance), dtype=torch.float32).to(device) for instance in instances[0]]\n",
    "                label = torch.tensor(label, dtype=torch.float32).to(device)\n",
    "\n",
    "                output = model(instances)\n",
    "                predicted = (output > 0.5).float()\n",
    "                total += label.size(0)\n",
    "                correct += (predicted == label).sum().item()\n",
    "\n",
    "                # 获取存储的权重\n",
    "                stored_weights = model.get_stored_weights()\n",
    "                break\n",
    "\n",
    "    accuracy = 100 * correct / total\n",
    "    print(f'Accuracy of the model on the selected dataset: {accuracy}%')\n",
    "\n",
    "    # 打印或分析存储的权重\n",
    "    for i, weights in enumerate(stored_weights):\n",
    "        print(f\"Bag {i} weights: {weights}\")\n",
    "        plt.figure()\n",
    "        plt.bar(range(len(weights[0])), weights[0])\n",
    "        plt.title(f\"Attention Weights for Bag {i}\")\n",
    "        plt.xlabel(\"Instance Index\")\n",
    "        plt.ylabel(\"Attention Weight\")\n",
    "        plt.show()\n"
   ]
  },
